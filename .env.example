# Copy to .env.local for local dev
# Add all of these to Vercel Environment Variables

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Vercel KV — from Vercel Dashboard > Storage
KV_REST_API_URL=https://your-kv.upstash.io
KV_REST_API_TOKEN=your-kv-token

# Clerk — from clerk.com > API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=your-clerk-secret-key-here

# Gmail SMTP — for email exports
# Use an App Password, NOT your regular Gmail password
# myaccount.google.com > Security > 2-Step Verification > App Passwords
GMAIL_USER=ledgerscanph@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
